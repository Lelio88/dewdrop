<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY network policy.

  Allows cleartext HTTP to the local dev hosts so the app can reach the
  Supabase stack running on the developer machine:
    - 10.0.2.2  → the host loopback as seen from the Android emulator
    - localhost / 127.0.0.1 → host when using adb reverse / physical-device tunnels

  This file lives under src/debug/ and therefore is merged ONLY into debug
  builds. Release builds keep Android's default (cleartext blocked, HTTPS only).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
