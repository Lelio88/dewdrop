<?xml version="1.0" encoding="utf-8"?>
<!-- DewDrop home-screen widget: a header + a row of up to four friend circles,
     with a sign-in/empty hint shown instead of the row when there is nothing to
     send to. Slot ids (slot{0..3}_root / _initial / _label) are read & written
     by DewDropWidgetProvider.kt and widget_sync_service.dart — keep in sync. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/widget_title"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/slots_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/slot0_root"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="2dp"
            android:paddingRight="2dp">
            <TextView
                android:id="@+id/slot0_initial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/slot0_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="#FFB8C6D0"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot1_root"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="2dp"
            android:paddingRight="2dp">
            <TextView
                android:id="@+id/slot1_initial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/slot1_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="#FFB8C6D0"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot2_root"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="2dp"
            android:paddingRight="2dp">
            <TextView
                android:id="@+id/slot2_initial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/slot2_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="#FFB8C6D0"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/slot3_root"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="2dp"
            android:paddingRight="2dp">
            <TextView
                android:id="@+id/slot3_initial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/widget_circle"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/slot3_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="#FFB8C6D0"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:gravity="center"
        android:text="@string/widget_hint"
        android:textColor="#FFB8C6D0"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
