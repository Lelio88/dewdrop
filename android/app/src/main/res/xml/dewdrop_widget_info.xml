<?xml version="1.0" encoding="utf-8"?>
<!-- AppWidget metadata. updatePeriodMillis=0: the widget is refreshed on demand
     by Flutter (WidgetSyncService → HomeWidget.updateWidget), never on a timer. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:minResizeWidth="180dp"
    android:maxResizeWidth="360dp"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/dewdrop_widget"
    android:previewLayout="@layout/dewdrop_widget"
    android:resizeMode="horizontal"
    android:widgetCategory="home_screen"
    android:configure="app.dewdrop.WidgetConfigActivity"
    android:widgetFeatures="reconfigurable|configuration_optional"
    android:description="@string/widget_description" />
