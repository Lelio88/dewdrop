# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Python tool (depth_split) — venv is huge (PyTorch)
tools/depth_split/.venv/
__pycache__/

# Supabase local working dirs (config + migrations ARE committed)
supabase/.branches/
supabase/.temp/

# Generated parallax layers — regenerate from base.png via tools/depth_split.
# (base.png sources and .gitkeep are kept.)
assets/photo/**/[0-9]*.png

# Secrets — NEVER commit (Firebase service account, etc.)
.env
**/.env
firebase-service-account.json
*-firebase-adminsdk-*.json

# Local emulator screenshots
.android-screenshot.png

# Audio working dir (raw downloads; final loops live in assets/audio)
tools/sounds/
